#include <stdio.h>

int main() {
    int n = 153, temp, sum = 0, rem;

    temp = n;

    while(n != 0) {
        rem = n % 10;
        sum = sum + rem * rem * rem;
        n = n / 10;
    }

    if(temp == sum)
        printf("Armstrong");
    else
        printf("Not Armstrong");

    return 0;
}
