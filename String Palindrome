#include <stdio.h>
#include <string.h>

int main() {
    char str[] = "madam";
    int i, len, flag = 0;

    len = strlen(str);

    for(i = 0; i < len/2; i++) {
        if(str[i] != str[len - i - 1]) {
            flag = 1;
            break;
        }
    }

    if(flag)
        printf("Not Palindrome");
    else
        printf("Palindrome");

    return 0;
}
